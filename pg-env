create_pgenv() {

cat >../${2}/.pg-env <<EOF
PGV=${1}
PG_DEV_NAME=${2}
#SKIP_MESON_BUILD=1
EOF

}

commitfest() {
    shift
    EntryID=$1
    PG_VERSION=$2
    echo "CommitFest Testing https://commitfest.postgresql.org/patch/$EntryID"
    PatchURL=$(curl -s https://commitfest.postgresql.org/patch/${EntryID}/ | sed -n 's/.*Latest attachment (<a href="\(.*\.patch\)">.*<\/a>.* at .*/\1/p')
    PatchFILE=$(echo $PatchURL | sed -n 's/http.*\/\(.*\)/\1/p')
    echo $PatchURL
    echo $PatchFILE
    EXIT_VALUE=0
    if [ $# -ne 1 ] && [ $# -ne 2 ]; then
        EXIT_VALUE=1
        echo "Usage: $0 commitfest <CommitFest Entity ID>"
        echo "or"
        echo "Usage: $0 commitfest <CommitFest Entity ID> <PG Major Version>"
    fi
    if [ ! -f src/include/postgres.h ] || [ ! -d .git ]; then
        EXIT_VALUE=1
        echo "Run this command from PostgreSQL git checkout"
    fi
    if [ $# -eq 1 ]; then
        branch_name=CF_${EntryID}
    else
        branch_name=CF_${EntryID}_${PG_VERSION}
    fi
    IsWorktreePresent=$(git worktree list | grep "${branch_name}")
    IsBranchPresent=$(git branch | grep "${branch_name}")
    FORCE_RESET=0
    if [ ! -z "${IsWorktreePresent}" ]; then
        EXIT_VALUE=1
        echo "Worktree already present, to remove it use following"
        echo "git worktree remove --force <worktree dir>"
        echo "git branch -d <branch name>"
    fi
    if [ ! -z "${IsBranchPresent}" ]; then
        EXIT_VALUE=1
        echo "Branch already present, to remove it use following"
        echo "git branch -d <branch name>"
    fi
    if [ $EXIT_VALUE -gt 0 ]; then
        echo -n "Force reset branch Y/N? (N) "
        read answer
        case "$answer" in
            y|Y)
                FORCE_RESET=1
                ;;
        esac
    fi
    if [ $EXIT_VALUE -eq 0 ] || [ $FORCE_RESET -gt 0 ]; then
        if [ $# -eq 1 ]; then
            if [ $FORCE_RESET -eq 1 ]; then
                git -C ../postgresql-${branch_name} reset --hard origin/master
            else
                git worktree add --track -b ${branch_name} ../postgresql-${branch_name}
                create_pgenv HEAD postgresql-${branch_name}
            fi
        else
            if [ $FORCE_RESET -eq 1 ]; then
                git -C ../postgresql-${branch_name} reset --hard origin/REL_${PG_VERSION}_STABLE
            else
                git worktree add --track -b ${branch_name} ../postgresql-${branch_name} origin/REL_${PG_VERSION}_STABLE
                create_pgenv ${PG_VERSION} postgresql-${branch_name}
            fi
        fi
        cd ../postgresql-${branch_name}
        git pull
        echo "Downloading patch: ${PatchFILE}"
        curl -s -O "${PatchURL}"
        git am "${PatchFILE}"
        EXIT_VALUE=$?
    fi
    exit $EXIT_VALUE
}

branch() {
    shift
    branch_name=$1
    echo "Create new worktree for ${branch_name}"
    EXIT_VALUE=0
    if [ $# -ne 1 ] && [ $# -ne 2 ]; then
        EXIT_VALUE=1
        echo "Usage: $0 branch <Name of new Branch>"
        echo "or"
        echo "Usage: $0 branch <Name of new Branch <PG_RELEASED_BRANCH_NAME>"
    fi
    if [ ! -f src/include/postgres.h ] || [ ! -d .git ]; then
        EXIT_VALUE=1
        echo "Run this command from PostgreSQL git checkout"
    fi
    if [ $# -eq 1 ]; then
        IsBranchPresent=$(git worktree list | grep "\[${branch_name}\]")
    else
        IsBranchPresent=$(git worktree list | grep "\[${branch_name}_${2}\]")
    fi
    if [ ! -z "${IsBranchPresent}" ]; then
        EXIT_VALUE=1
        echo "Worktree already present, to remove it use following"
        echo "git worktree remove --force <worktree dir>"
        echo "git branch -d <branch name>"
    fi
    if [ $EXIT_VALUE -eq 0 ]; then
        if [ $# -eq 1 ]; then
            git worktree add --track -b ${branch_name} ../postgresql-${branch_name}
            create_pgenv HEAD postgresql-${branch_name}
        else
            git worktree add --track -b ${branch_name}_${2} ../postgresql-${branch_name}_${2} origin/$2
            create_pgenv $(grep PACKAGE_VERSION ../postgresql-${branch_name}_${2}/configure | grep -o '[0-9]*' | head -1) postgresql-${branch_name}_${2}
        fi
        EXIT_VALUE=$?
    fi
    exit $EXIT_VALUE
}

if [ "$0" = "$BASH_SOURCE" ]; then
    if [ "$1" = "commitfest" ]; then
        commitfest $@
    fi
    if [ "$1" = "branch" ]; then
        branch $@
    fi
    echo "source $0"
    echo "$0 branch <new branch name>"
    echo "$0 commitfest <CommitFest Entity ID> <PG Major Version>"
    exit 1
fi
SAVED_PGV=${PGV}
if [[ -f ~/.pg-env ]]; then
    [ ! -z "$PG_ENV_DEBUG" ] && echo "Loading ~/.pg-env"
    source ~/.pg-env
fi
if [[ -f .pg-env ]]; then
    [ ! -z "$PG_ENV_DEBUG" ] && echo "Loading .pg-env"
    source .pg-env
fi

if [ -z "$GIT_DIR" ]; then
    GIT_DIR=${HOME}/gitwork
fi
if [ -z "$PG_DEV_NAME" ]; then
    PG_DEV_NAME="postgresql-${PGV}"
fi
if [ -z "$PG_INST_NAME" ]; then
    PG_INST_NAME="${PG_DEV_NAME}-INST"
fi
[ ! -z "$PG_ENV_DEBUG" ] && echo "GIT_DIR $GIT_DIR"
[ ! -z "$PG_ENV_DEBUG" ] && echo "PG_DEV_NAME $PG_DEV_NAME"
[ ! -z "$PG_ENV_DEBUG" ] && echo "PG_INST_NAME $PG_INST_NAME"

if [ -z "$SAVED_PATH" ]; then
    SAVED_PATH=${PATH}
fi
if [ -z "$SAVED_PS1" ]; then
    SAVED_PS1=${PS1}
fi
if [ -z "$SAVED_VIRTUAL_ENV" ]; then
    SAVED_VIRTUAL_ENV=${VIRTUAL_ENV}
fi
if [ "$0" = "$BASH_SOURCE" ] && [ ! "$1" = "" ]; then
    PGV=${1}
fi
if [ -z "$PGV" ]; then
    echo "Missing PGV, export PGV=HEAD or export PGV=15"
else
    if [ -z "$PG_ENV_VENV" ]; then
        if [ -z "$PG_DEV_SRC" ]; then
            PG_DEV_SRC=${GIT_DIR}/${PG_DEV_NAME}
        fi
        PG_DEV_INST=${GIT_DIR}/${PG_INST_NAME}
        if [ ! -d "${PG_DEV_SRC}" ] || [ ! -d "${PG_DEV_INST}" ]; then
            echo "Missing source worktree/clone in ${PG_DEV_SRC} or ${PG_DEV_INST}"
            echo "git worktree add --track -b <local branch> ../<local dir> origin/<Branch/TAG>\ngit clone ...\n\n"
            echo "git worktree add --track -b REL_${PGV}_STABLE ../${PG_DEV_NAME} origin/REL_${PGV}_STABLE"
            echo "mkdir -p ${PG_DEV_INST}"
        else
            if [ -f "${PG_DEV_SRC}/meson.build" ]; then
                [ -z "$SKIP_MESON_BUILD" ] && export MESON_BUILD_PRESENT=1
            fi
            export PG_ENV_VENV=1
            export SAVED_LD_LIBRARY_PATH=${LD_LIBRARY_PATH}
            export SAVED_PGDATA=${PGDATA}
            export SAVED_PGPORT=${PGPORT}
            export SAVED_PGDATABASE=${PGDATABASE}

            export PS1="(PG:${PGV}) ${SAVED_PS1}"
            export VIRTUAL_ENV="PG:${PGV}"
            export PG_DEV_SRC
            export PG_DEV_INST
            export PG_BIN=${PG_DEV_INST}/bin
            export PGDATA=${PG_DEV_INST}/data
            export PGDATABASE=postgres
            export LD_LIBRARY_PATH=${PG_DEV_INST}/lib
            export PATH=${PG_BIN}:${SAVED_PATH}
            if [[ $PGV =~ ^[0-9]+$ ]]; then
                export PGPORT=54${PGV}
            else
                export PGPORT=5432
            fi
        help() {
            local build_sys="autoconf (make)"
            [ -n "${MESON_BUILD_PRESENT}" ] && build_sys="meson (ninja)"
            echo "pg-env - PostgreSQL Development Environment (PGV=${PGV}, ${build_sys})"
            echo "========================================================="
            echo ""
            echo "INFO"
            echo "  penv              Show current pg-env variables"
            echo "  status            Show running PostgreSQL instances and ports"
            echo "  pglog [N]         Tail the latest log (node N, or default instance)"
            echo ""
            echo "BUILD (using ${build_sys})"
            echo "  configure         Run ./configure or meson setup (with version-specific flags)"
            echo "  compile           Build PostgreSQL"
            echo "  install           Install PostgreSQL to \$PG_DEV_INST"
            echo "  compile_contrib   Build and install contrib modules (autoconf only)"
            echo "  distclean         Stop all, clean data/install, and distclean source tree"
            echo "  docs              Generate documentation"
            echo ""
            echo "DATABASE LIFECYCLE"
            echo "  setupdb [N ...]   Initialize database(s) with initdb"
            echo "  startdb [N ...]   Start database instance(s)"
            echo "  stopdb [N ...]    Stop database instance(s)"
            echo "  restartdb [N ...] Stop and start database instance(s)"
            echo "                    (no args = default instance, N = node number)"
            echo ""
            echo "CLEANUP & RESET"
            echo "  cleandb [N ...]   Stop and remove database data dir(s)"
            echo "  cleaninst         Remove PG install directory"
            echo "  cleanall [N ...]  cleandb + cleaninst"
            echo "  resetdb [N ...]   cleandb + setupdb + startdb"
            echo "  resetinst         distclean + configure + compile + install + compile_contrib"
            echo "  resetall [N ...]  resetinst + resetdb"
            echo ""
            echo "QUERY & TEST"
            echo "  pexec [N ...] [PEXEC_CMD=\"...\"]"
            echo "                    Run psql on default or specified nodes"
            echo "                    e.g. pexec 1 2 3 PEXEC_CMD=\"-c 'SELECT 1'\""
            if [ -z "${MESON_BUILD_PRESENT}" ]; then
            echo "  c                 make check (core regression tests)"
            echo "  cw                make check-world (all tests)"
            echo "  ic                make installcheck (against running instance)"
            echo "  icw               make installcheck-world (against running instance)"
            else
            echo "  c                 meson test --suite setup --suite regress"
            echo "  cw                meson test (all suites)"
            echo "  ic                meson test --setup running --suite regress-running"
            echo "  icw               meson test --setup running (all suites)"
            fi
            echo "  r <test> [...]    Run specific SQL regression test(s)"
            echo "                    e.g. r int4 int8"
            echo "  t <test.pl> [...]  Run specific TAP/Perl test(s)"
            echo "                    e.g. t src/test/recovery/t/001_stream_rep.pl"
            echo "                    e.g. t t/001_stream_rep.pl  (from test directory)"
            echo ""
            echo "DEACTIVATING VIRTUAL ENVIRONMENT"
            echo "  deactivate        Stop all instances and deactivate pg-env"
            echo ""
            echo "CONFIGURATION (set in ~/.pg-env or .pg-env):"
            echo "  PGV                          PostgreSQL version (e.g. 18, HEAD)"
            echo "  PG_DEV_NAME                  Source directory name"
            echo "  PG_INST_NAME                 Install directory name"
            echo "  PG_ENV_CFLAGS                Extra CFLAGS for builds"
            echo "  PG_ENV_CONFIGURE_FLAGS       Extra ./configure flags (all versions)"
            echo "  PG_ENV_CONFIGURE_FLAGS_<V>   Version-specific ./configure flags"
            echo "  PG_ENV_MESON_FLAGS           Extra meson setup flags (all versions)"
            echo "  PG_ENV_MESON_FLAGS_<V>       Version-specific meson setup flags"
            echo "  SKIP_MESON_BUILD             Set to force autoconf even if meson.build exists"
            echo ""
            echo "POSTGRESQL CONFIGURATION FILES (included by setupdb):"
            echo "  \${GIT_DIR}/pgconfigs/pg\${PGV}.conf       Global config for default instance"
            echo "  \${GIT_DIR}/pgconfigs/pg\${PGV}-N.conf     Global config for node N"
            echo "  ./.\pg\${PGV}.conf                         Local overlay for default instance"
            echo "  ./.pg\${PGV}-N.conf                        Local overlay for node N"
        }

        _validate_nodes() {
            local _rc=0
            for _n in "$@"; do
                if ! [[ "$_n" =~ ^[1-5]$ ]]; then
                    echo "ERROR: Invalid node number '${_n}' (must be 1-5)"
                    _rc=1
                fi
            done
            return $_rc
        }

        penv() {
            echo "PGV:              ${PGV}"
            echo "PG_DEV_SRC:       ${PG_DEV_SRC}"
            echo "PG_DEV_INST:      ${PG_DEV_INST}"
            echo "PGDATA:           ${PGDATA}"
            echo "PGPORT:           ${PGPORT}"
            echo "PGDATABASE:       ${PGDATABASE}"
            echo "PG_BIN:           ${PG_BIN}"
            echo "LD_LIBRARY_PATH:  ${LD_LIBRARY_PATH}"
            echo "MESON_BUILD:      ${MESON_BUILD_PRESENT:-no}"
            echo "EXTRA CFLAGS:     ${PG_ENV_CFLAGS}"
        }

        status() {
            echo "=== PostgreSQL instances ==="
            if pg_isready -q -p ${PGPORT}; then
                local pid=$(head -1 "${PGDATA}/postmaster.pid" 2>/dev/null)
                echo "  default  port=${PGPORT}  pid=${pid:-?}  RUNNING  data=${PGDATA}"
            elif [ -d "${PGDATA}" ]; then
                echo "  default  port=${PGPORT}  STOPPED  data=${PGDATA}"
            fi
            local NodeN
            for NodeN in 1 2 3 4 5; do
                if pg_isready -q -p "${NodeN}${PGPORT}"; then
                    local pid=$(head -1 "${PGDATA}-${NodeN}/postmaster.pid" 2>/dev/null)
                    echo "  node-${NodeN}   port=${NodeN}${PGPORT}  pid=${pid:-?}  RUNNING  data=${PGDATA}-${NodeN}"
                elif [ -d "${PGDATA}-${NodeN}" ]; then
                    echo "  node-${NodeN}   port=${NodeN}${PGPORT}  STOPPED  data=${PGDATA}-${NodeN}"
                fi
            done
        }

        pglog() {
            [ $# -gt 0 ] && { _validate_nodes "$@" || return 1; }
            local logdir
            local node="${1}"
            if [ -z "${node}" ]; then
                logdir="${PGDATA}/log"
            else
                logdir="${PGDATA}-${node}/log"
            fi
            if [ ! -d "${logdir}" ]; then
                echo "No log directory at ${logdir}"
                return 1
            fi
            local latest=$(ls -t "${logdir}"/*.log 2>/dev/null | head -1)
            if [ -z "${latest}" ]; then
                echo "No log files in ${logdir}"
                return 1
            fi
            echo "Tailing ${latest} (Ctrl-C to stop)"
            tail -f "${latest}"
        }

        configure() {
            # Version-specific flags: PG_ENV_CONFIGURE_FLAGS_<VER> > PG_ENV_CONFIGURE_FLAGS
            local ver_upper=$(echo "${PGV}" | tr '[:lower:]' '[:upper:]')
            local extra_configure extra_meson
            eval "extra_configure=\${PG_ENV_CONFIGURE_FLAGS_${ver_upper}:-\$PG_ENV_CONFIGURE_FLAGS}"
            eval "extra_meson=\${PG_ENV_MESON_FLAGS_${ver_upper}:-\$PG_ENV_MESON_FLAGS}"

            pushd "${PG_DEV_SRC}" >/dev/null
            if [ -z "${MESON_BUILD_PRESENT}" ]; then
                (
                    time ./configure \
                        --prefix=${PG_DEV_INST} \
                        --with-pgport=${PGPORT} \
                        --enable-cassert \
                        --enable-debug \
                        --enable-tap-tests \
                        --with-perl \
                        --with-python \
                        --with-ssl=openssl \
                        --with-systemd \
                        --with-lz4 \
                        --with-zstd \
                        ${extra_configure} \
                        CFLAGS="-ggdb -O0 -g3 -ggdb3 -fno-omit-frame-pointer ${PG_ENV_CFLAGS}"
                ) |& tee /tmp/pg_configure.log
                local setup_rc=${PIPESTATUS[0]}
            else
                (
                    time meson setup build \
                        --prefix=${PG_DEV_INST} \
                        --buildtype=debug \
                        -Dpgport=${PGPORT} \
                        -Dcassert=true \
                        -Ddebug=true \
                        -Dinjection_points=true \
                        -Dplperl=enabled \
                        -Dplpython=enabled \
                        -Dssl=openssl \
                        -Dsystemd=enabled \
                        -Dtap_tests=enabled \
                        -Dlz4=enabled \
                        -Dzstd=enabled \
                        ${extra_meson} \
                        -Dc_args="-ggdb -O0 -g3 -ggdb3 -fno-omit-frame-pointer ${PG_ENV_CFLAGS}"
                ) |& tee /tmp/pg_configure.log
                local setup_rc=${PIPESTATUS[0]}
            fi
            popd >/dev/null
            if [ $setup_rc -gt 0 ]; then
                if [ -z "${MESON_BUILD_PRESENT}" ]; then
                    echo "Configure failed"
                else
                    echo "meson setup failed"
                fi
                return 1
            fi
        }

        compile() {
            if [ -z "${MESON_BUILD_PRESENT}" ]; then
                [ ! -f "${PG_DEV_SRC}/config.status" ] && { configure || return 1; }
            else
                [ ! -f "${PG_DEV_SRC}/build/build.ninja" ] && { configure || return 1; }
            fi
            pushd "${PG_DEV_SRC}" >/dev/null
            if [ -z "${MESON_BUILD_PRESENT}" ]; then
                time make -j |& tee /tmp/pg_compile.log
                local build_rc=${PIPESTATUS[0]}
            else
                (
                    cd build
                    time ninja -v
                ) |& tee /tmp/pg_compile.log
                local build_rc=${PIPESTATUS[0]}
            fi
            popd >/dev/null
            if [ $build_rc -gt 0 ]; then
                echo "Compile failed"
                return 1
            fi
        }

        install() {
            if [ -z "${MESON_BUILD_PRESENT}" ]; then
                [ ! -f "${PG_DEV_SRC}/src/backend/postgres" ] && { compile || return 1; }
            else
                [ ! -f "${PG_DEV_SRC}/build/src/backend/postgres" ] && { compile || return 1; }
            fi
            pushd "${PG_DEV_SRC}" >/dev/null
            if [ -z "${MESON_BUILD_PRESENT}" ]; then
                time make -j install |& tee /tmp/pg_install.log
                local install_rc=${PIPESTATUS[0]}
            else
                (
                    cd build
                    time ninja install
                ) |& tee /tmp/pg_install.log
                local install_rc=${PIPESTATUS[0]}
            fi
            popd >/dev/null
            if [ $install_rc -gt 0 ]; then
                echo "Install failed"
                return 1
            fi
        }

        compile_contrib() {
            if [ -z "${MESON_BUILD_PRESENT}" ]; then
                pushd "${PG_DEV_SRC}/contrib" >/dev/null
                (time make -j install) |& tee -a /tmp/pg_compile.log
                if [ ${PIPESTATUS[0]} -gt 0 ]; then
                    echo "make install failed"
                fi
                popd >/dev/null
            fi
        }

        distclean() {
            cleanall
            if [ -z "${MESON_BUILD_PRESENT}" ]; then
                pushd "${PG_DEV_SRC}" >/dev/null
                make -j clean
                make -j distclean
            else
                pushd "${PG_DEV_SRC}/build" >/dev/null
                ninja clean
            fi
            popd >/dev/null
        }

        docs() {
            if [ -z "${MESON_BUILD_PRESENT}" ]; then
                pushd "${PG_DEV_SRC}" >/dev/null
                (time make -j docs) |& tee -a /tmp/pg_docs.log
            else
                pushd "${PG_DEV_SRC}/build" >/dev/null
                ninja docs |& tee -a /tmp/pg_docs.log
            fi
            popd >/dev/null
        }

        setupdb() {
            [ ! -f "${PG_BIN}/postgres" ] && { install || return 1; }
            [ $# -gt 0 ] && { _validate_nodes "$@" || return 1; }
            if [ -z "$1" ]; then
                initdb --data-checksums --username=${USER}
                echo "include = '${GIT_DIR}/pgconfigs/pg${PGV}.conf'" >>"${PGDATA}/postgresql.conf"
                if [ -f "$(pwd)/.pg${PGV}.conf" ]; then
                    echo "include = '$(pwd)/.pg${PGV}.conf'" >>"${PGDATA}/postgresql.conf"
                fi
            else
                for NodeN in "$@"; do
                    initdb --data-checksums --username=${USER} -D "${PGDATA}-${NodeN}"
                    echo "include = '${GIT_DIR}/pgconfigs/pg${PGV}-${NodeN}.conf'" >>"${PGDATA}-${NodeN}/postgresql.conf"
                    if [ -f "$(pwd)/.pg${PGV}-${NodeN}.conf" ]; then
                        echo "include = '$(pwd)/.pg${PGV}-${NodeN}.conf'" >>"${PGDATA}-${NodeN}/postgresql.conf"
                    fi
                done
            fi
        }

        startdb() {
            [ $# -gt 0 ] && { _validate_nodes "$@" || return 1; }
            if [ -z "$1" ]; then
                [ ! -f "${PGDATA}/PG_VERSION" ] && { setupdb || return 1; }
                pg_isready -q -p ${PGPORT} || pg_ctl start
            else
                for NodeN in "$@"; do
                    [ ! -f "${PGDATA}-${NodeN}/PG_VERSION" ] && { setupdb "${NodeN}" || return 1; }
                    pg_isready -q -p "${NodeN}${PGPORT}" || pg_ctl start -D "${PGDATA}-${NodeN}"
                done
            fi
        }

        stopdb() {
            [ $# -gt 0 ] && { _validate_nodes "$@" || return 1; }
            if [ -z "$1" ]; then
                pg_isready -q -p ${PGPORT} && pg_ctl stop
            else
                for NodeN in "$@"; do
                    pg_isready -q -p "${NodeN}${PGPORT}" && pg_ctl stop -D "${PGDATA}-${NodeN}"
                done
            fi
        }

        restartdb() {
            [ $# -gt 0 ] && { _validate_nodes "$@" || return 1; }
            stopdb "$@"
            if [ -z "$1" ]; then
                [ ! -f "${PGDATA}/PG_VERSION" ] && { setupdb || return 1; }
            else
                for NodeN in "$@"; do
                    [ ! -f "${PGDATA}-${NodeN}/PG_VERSION" ] && { setupdb "${NodeN}" || return 1; }
                done
            fi
            startdb "$@"
        }

        cleandb() {
            [ $# -gt 0 ] && { _validate_nodes "$@" || return 1; }
            stopdb "$@"
            if [ -z "$1" ]; then
                [ -n "$ZSH_VERSION" ] && setopt localoptions rmstarsilent
                rm -rf "${PGDATA:?PGDATA is not set}"/*
            else
                for NodeN in "$@"; do
                    [ -n "$ZSH_VERSION" ] && setopt localoptions rmstarsilent
                    rm -rf "${PGDATA:?PGDATA is not set}-${NodeN}"/*
                done
            fi
        }

        cleaninst() {
            [ -n "$ZSH_VERSION" ] && setopt localoptions rmstarsilent
            rm -rf "${PG_DEV_INST:?PG_DEV_INST is not set}"/*
        }

        cleanall() {
            cleandb "$@"
            cleaninst "$@"
        }

        resetdb() {
            cleandb "$@"
            setupdb "$@"
            startdb "$@"
        }

        resetinst() {
            distclean
            configure && compile && install
            compile_contrib
        }

        resetall() {
            resetinst "$@"
            resetdb "$@"
        }

        pexec() {
            local PEXEC_CMD=""
            local nodes=()
            while [ $# -gt 0 ]; do
                case "$1" in
                --PEXEC_CMD=* | PEXEC_CMD=*)
                    PEXEC_CMD="${1#*=}"
                    ;;
                *)
                    nodes+=("$1")
                    ;;
                esac
                shift
            done
            if [ ${#nodes[@]} -eq 0 ]; then
                echo "psql -U ${USER} ${PEXEC_CMD}"
                psql -U "${USER}" ${PEXEC_CMD}
            else
                for NodeN in "${nodes[@]}"; do
                    echo "psql -U ${USER} -p ${NodeN}${PGPORT} ${PEXEC_CMD}"
                    psql -U "${USER}" -p "${NodeN}${PGPORT}" ${PEXEC_CMD}
                done
            fi
        }

        c() {
            if [ -z "${MESON_BUILD_PRESENT}" ]; then
                pushd "${PG_DEV_SRC}" >/dev/null
                make -j check |& tee /tmp/pg_c.log
            else
                pushd "${PG_DEV_SRC}/build" >/dev/null
                meson test -q --print-errorlogs --suite setup --suite regress |& tee /tmp/pg_c.log
            fi
            popd >/dev/null
        }

        cw() {
            if [ -z "${MESON_BUILD_PRESENT}" ]; then
                pushd "${PG_DEV_SRC}" >/dev/null
                make -j check-world |& tee /tmp/pg_cw.log
            else
                pushd "${PG_DEV_SRC}/build" >/dev/null
                meson test -q --print-errorlogs |& tee /tmp/pg_cw.log
            fi
            popd >/dev/null
        }

        ic() {
            if [ -z "${MESON_BUILD_PRESENT}" ]; then
                pushd "${PG_DEV_SRC}" >/dev/null
                make -j installcheck |& tee /tmp/pg_ic.log
            else
                pushd "${PG_DEV_SRC}/build" >/dev/null
                meson test -q --print-errorlogs --setup running --suite regress-running |& tee /tmp/pg_ic.log
            fi
            popd >/dev/null
        }

        icw() {
            if [ -z "${MESON_BUILD_PRESENT}" ]; then
                pushd "${PG_DEV_SRC}" >/dev/null
                make -j installcheck-world |& tee /tmp/pg_icw.log
            else
                pushd "${PG_DEV_SRC}/build" >/dev/null
                meson test -q --print-errorlogs --setup running |& tee /tmp/pg_icw.log
            fi
            popd >/dev/null
        }

        r() {
            if [ -z "$1" ]; then
                echo "Usage: r <test_name> [test_name ...]"
                echo "  e.g. r int4 int8"
                echo "  e.g. r src/test/regress/sql/int4.sql"
                return 1
            fi
            local tests=()
            for arg in "$@"; do
                tests+=($(basename "${arg}" .sql))
            done
            if [ -z "${MESON_BUILD_PRESENT}" ]; then
                pushd "${PG_DEV_SRC}/src/test/regress" >/dev/null
                ${PG_BIN}/pg_regress --inputdir=. --bindir="${PG_BIN}" --dlpath=. --schedule=<(printf '%s\n' "test: ${tests[*]}") |& tee /tmp/pg_r.log
            else
                pushd "${PG_DEV_SRC}/build" >/dev/null
                meson test -q --print-errorlogs ${tests[@]/#/regress-} |& tee /tmp/pg_r.log
            fi
            popd >/dev/null
        }

        t() {
            if [ -z "$1" ]; then
                echo "Usage: t <test.pl> [test.pl ...]"
                echo "  e.g. t src/test/recovery/t/001_stream_rep.pl"
                echo "  e.g. t t/001_stream_rep.pl  (from CWD)"
                return 1
            fi
            for tp in "$@"; do
                local tap_dir
                if [[ "${tp}" = /* ]]; then
                    tap_dir=$(dirname "${tp}")
                elif [[ "${tp}" = t/* ]]; then
                    tap_dir=$(pwd)
                else
                    tap_dir="${PG_DEV_SRC}/$(dirname "${tp}")"
                fi
                local tap_file=$(basename "${tp}")
                echo "Running TAP test: ${tap_dir}/t/${tap_file}"
                pushd "${tap_dir}" >/dev/null
                prove -v "t/${tap_file}" |& tee /tmp/pg_t.log
                popd >/dev/null
            done
        }

        deactivate() {
            stopdb
            stopdb 1 2 3 4 5
            export PATH=${SAVED_PATH}
            export PS1=${SAVED_PS1}
            if [ ! -z "$VIRTUAL_ENV" ]; then
                export VIRTUAL_ENV=${SAVED_VIRTUAL_ENV}
            else
                unset VIRTUAL_ENV
            fi
            if [ ! -z "$SAVED_LD_LIBRARY_PATH" ]; then
                export LD_LIBRARY_PATH=${SAVED_LD_LIBRARY_PATH}
            else
                unset LD_LIBRARY_PATH
            fi
            if [ ! -z "$SAVED_PGDATA" ]; then
                export PGDATA=${SAVED_PGDATA}
            else
                unset PGDATA
            fi
            if [ ! -z "$SAVED_PGPORT" ]; then
                export PGPORT=${SAVED_PGPORT}
            else
                unset PGPORT
            fi
            if [ ! -z "$SAVED_PGDATABASE" ]; then
                export PGDATABASE=${SAVED_PGDATABASE}
            else
                unset PGDATABASE
            fi
            if [ ! -z "$SAVED_PGV" ]; then
                export PGV=${SAVED_PGV}
            else
                unset PGV
            fi
            unset -f _validate_nodes
            unset -f c
            unset -f cleanall
            unset -f cleandb
            unset -f cleaninst
            unset -f compile
            unset -f compile_contrib
            unset -f configure
            unset -f install
            unset -f cw
            unset -f deactivate
            unset -f distclean
            unset -f docs
            unset -f help
            unset -f ic
            unset -f icw
            unset -f penv
            unset -f pexec
            unset -f pglog
            unset -f resetall
            unset -f resetdb
            unset -f resetinst
            unset -f restartdb
            unset -f setupdb
            unset -f startdb
            unset -f status
            unset -f stopdb
            unset -f r
            unset -f t
            unset GIT_DIR
            unset MESON_BUILD_PRESENT
            unset PG_BIN
            unset PG_DEV_INST
            unset PG_DEV_NAME
            unset PG_DEV_SRC
            unset PG_ENV_VENV
            unset PG_INST_NAME
            unset SAVED_LD_LIBRARY_PATH
            unset SAVED_PATH
            unset SAVED_PGDATA
            unset SAVED_PGDATABASE
            unset SAVED_PGPORT
            unset SAVED_PS1
            unset SAVED_PGV
            unset SAVED_VIRTUAL_ENV
            unset SKIP_MESON_BUILD
        }
        fi
    else
        echo "Already in pg-env VENV"
    fi
fi
